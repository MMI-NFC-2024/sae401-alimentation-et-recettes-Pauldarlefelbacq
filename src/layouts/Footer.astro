---
import logo from '../assets/logo.svg';

interface Props {
    color: string
}
const { color = 'beige' } = Astro.props;
---

<footer class={`bg-${color} text-bleu border border-b-${color} mx-5 mt-12 py-8 rounded-t-xl`}>
    <div class="w-9/10 mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-center gap-8 mb-8">
            <div class="flex flex-col items-center md:items-start gap-3 flex-1">
                <img src={logo.src} alt="Logo" class="h-16 w-auto" />
                <p class="text-center md:text-left max-w-xs">
                    Découvrez des recettes délicieuses et des conseils nutritionnels de nos coachs experts.
                </p>
            </div>

            <div class="flex flex-col items-center gap-2">
                <h3 class="font-bold text-lg mb-2">Navigation</h3>
                <a href="/" class="hover:text-bleu/80 transition-colors">Accueil</a>
                <a href="/recettes" class="hover:text-bleu/80 transition-colors">Recettes</a>
                <a href="/ingredients" class="hover:text-bleu/80 transition-colors">Ingrédients</a>
                <a href="/coachs" class="hover:text-bleu/80 transition-colors">Coachs</a>
            </div>

            <div class="flex flex-col items-center gap-2">
                <h3 class="font-bold text-lg mb-2">À propos</h3>
                <a href="/a-propos#conditions-utilisation" class="hover:text-bleu/80 transition-colors">Conditions d'utilisation</a>
                <a href="/a-propos#politique-confidentialite" class="hover:text-bleu/80 transition-colors">Politique de confidentialité</a>
                <a href="/a-propos#contact" class="hover:text-bleu/80 transition-colors">Contact</a>
            </div>
        </div>

        <div class="border-t border-beige my-6"></div>

        <div class="text-center text-sm opacity-80">
            <p>Projet réalisé dans le cadre des études</p>
        </div>
    </div>
</footer>
<style>
    a {
        text-decoration: underline;
    }

    a:hover {
        text-decoration: none;
    }
</style>