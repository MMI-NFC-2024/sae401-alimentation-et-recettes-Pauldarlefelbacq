---
import CardCommentaireCoach from "../../components/CardCommentaireCoach.astro";
import ImgPb from "../../components/ImgPb.astro";
import ProgressBar from "../../components/Progress_bar.astro";
import Layout from "../../layouts/Layout.astro";
import { UsersSpecialisationOptions, type CommentairesCoachResponse, type CommentairesResponse, type FavoriResponse, type FicheCoachResponse, type RecettesResponse, type UsersResponse } from "../../pocketbase-types";

type CommentaireCoachWithUser = CommentairesCoachResponse & {
    expand?: {
        user?: UsersResponse;
    };
};

type FavoriWithRecette = FavoriResponse & {
    expand?: {
        recette?: RecettesResponse;
    };
};

const user = Astro.locals.pb.authStore.record as UsersResponse & { id: string } | null;

const specialisations = Object.values(UsersSpecialisationOptions);

if (!user) {
    return Astro.redirect(`/authpassword`, 303);
}

const ficheCoach = user.coach ? await Astro.locals.pb.collection("Fiche_coach").getFullList<FicheCoachResponse>({
    filter: `user = "${user.id}"`
}) : [];

const commentaires = user.coach ? await Astro.locals.pb.collection("Commentaires_coach").getFullList<CommentaireCoachWithUser>({
    filter: `coach = "${user.id}"`,
    expand: "user"
}) : [];

const fiche = ficheCoach[0];
const moyenne = commentaires.length > 0
    ? (Math.round((commentaires.reduce((sum, r) => sum + Number(r.note), 0) / commentaires.length) * 10)) / 10
    : 0;
const nb_com = commentaires.length;

if (Astro.request.method === "POST") 
{
    const data = await Astro.request.formData();
    if (data.has("delete")) 
    {
        try
        {
            const id = data.get("recette") as string;

            await Astro.locals.pb.collection("Recettes").delete(id);
            return Astro.redirect(`/profil`, 303);
        }catch(e) {
        if (e instanceof Error) {
        console.error("Delete error:", e.message);
            }
        }
    }

    if (data.has("unfavorite")) 
    {
        try {
            const favoriId = data.get("favori") as string;
            if (favoriId) {
                await Astro.locals.pb.collection("Favori").delete(favoriId);
            }
            return Astro.redirect(`/profil`, 303);
        } catch (e) {
            if (e instanceof Error) {
                console.error("Unfavorite error:", e.message);
            }
        }
    }

    try 
    {
        const name = data.get("name") as string;
        const surname = data.get("surname") as string;
        const email = data.get("email") as string;
        const description = data.get("description") as string;
        const pseudo = data.get("pseudo") as string;

        const avatarInput = data.get("avatar");
        const avatar = avatarInput instanceof File && avatarInput.size > 0 ? avatarInput : undefined;

        const payload: Record<string, unknown> = {
            name,
            surname,
            email,
            description,
            pseudo,
        };

        if (avatar) {
            payload.avatar = avatar;
        }

        await Astro.locals.pb.collection("users").update(user.id, payload);
        return Astro.redirect(`/profil`, 303);
    }catch(e) {
        if (e instanceof Error) {
        console.error(e.message);
        }
    }
}

const recettesUser = await Astro.locals.pb.collection("Recettes").getFullList({
    expand: 'user',
    filter: `user = "${user.id}"`
});

const recetteStats: Record<string, { moyenne: number; nbAvis: number }> = {};

recettesUser.forEach((recette) => {
    recetteStats[recette.id] = { moyenne: 0, nbAvis: 0 };
});
if (recettesUser.length > 0) {
    const recetteFilter = recettesUser
        .map((recette) => `recette = "${recette.id}"`)
        .join(" || ");

    const commentairesRecettes = await Astro.locals.pb.collection("Commentaires").getFullList<CommentairesResponse>({
        filter: recetteFilter,
    });

    const sums: Record<string, { total: number; count: number }> = {};

    commentairesRecettes.forEach((commentaire) => {
        if (!commentaire.recette) return;

        if (!sums[commentaire.recette]) {
            sums[commentaire.recette] = { total: 0, count: 0 };
        }

        sums[commentaire.recette].total += Number(commentaire.note) || 0;
        sums[commentaire.recette].count += 1;
    });

    Object.entries(sums).forEach(([recetteId, value]) => {
        recetteStats[recetteId] = {
            moyenne: value.count > 0 ? Math.round((value.total / value.count) * 10) / 10 : 0,
            nbAvis: value.count,
        };
    });
}

const recettesFavUser = await Astro.locals.pb.collection("Favori").getFullList<FavoriWithRecette>({
    expand: "recette",
    filter: `user = "${user.id}"`
})

const favRecetteStats: Record<string, { moyenne: number; nbAvis: number }> = {};
const favRecetteIds = recettesFavUser
    .map((favori) => favori.expand?.recette?.id)
    .filter((id): id is string => Boolean(id));

if (favRecetteIds.length > 0) {
    const favFilter = favRecetteIds
        .map((recetteId) => `recette = "${recetteId}"`)
        .join(" || ");

    const commentairesFavRecettes = await Astro.locals.pb.collection("Commentaires").getFullList<CommentairesResponse>({
        filter: favFilter,
    });

    const favSums: Record<string, { total: number; count: number }> = {};

    commentairesFavRecettes.forEach((commentaire) => {
        if (!commentaire.recette) return;

        if (!favSums[commentaire.recette]) {
            favSums[commentaire.recette] = { total: 0, count: 0 };
        }

        favSums[commentaire.recette].total += Number(commentaire.note) || 0;
        favSums[commentaire.recette].count += 1;
    });

    Object.entries(favSums).forEach(([recetteId, value]) => {
        favRecetteStats[recetteId] = {
            moyenne: value.count > 0 ? Math.round((value.total / value.count) * 10) / 10 : 0,
            nbAvis: value.count,
        };
    });
}
---
<Layout titre={`Profil ${user.name || user.pseudo}`} color="beige">
    <main class="mt-12 *:my-5">
        <div class="flex flex-col bg-beige border border-bleu rounded-xl w-9/10 mx-auto p-2 place-items-center justify-around">
            <div class="flex">
                <div class="h-42 w-auto">
                    <ImgPb
                        record={user}
                        image={user.avatar}
                        alt={`avatar de ${user.name || user.pseudo}`}
                        classPicture="w-full h-full"
                        classImg="w-full h-full object-cover rounded-full"
                    />
                </div>
                <div class="flex flex-col h-fit *:my-1">
                    <p class="font-rampart text-2xl text-bleu">{user.surname} {user.name}</p>
                    <p class="text-base">@{user.pseudo}</p>
                    {user.coach && (
                        <p class=" text-bleu font-bold">Coach</p>
                    )}
                </div>
            </div>
            <button id="edit-user" class="block bg-bleu text-beige border rounded-xl cursor-pointer hover:bg-beige hover:text-bleu transition-all duration-100 p-3 mx-auto">
                Editer le profil
            </button>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 gap-3 justify-around">
            <button id="recettes-user" class="block bg-bleu text-beige border rounded-xl cursor-pointer hover:bg-beige hover:text-bleu transition-all duration-100 p-3 mx-auto">
                Vos recettes
            </button>
            <button id="recettes-user-fav" class="block bg-bleu text-beige border rounded-xl cursor-pointer hover:bg-beige hover:text-bleu transition-all duration-100 p-3 mx-auto">
                Vos favoris
            </button>
            <a href="/authpassword" class="block bg-bleu text-red-400 border rounded-xl cursor-pointer hover:bg-red-400 hover:text-beige transition-all duration-100 p-3 mx-auto">
                Se déconnecter
            </a>
        </div>

        <div id="edit-profile-user" class="fixed inset-0 bg-black bg-opacity-50 z-50 h-full items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
            <div class="bg-white rounded-lg p-5 max-w-md w-full relative">
                <button id="closeUser" class="absolute top-3 right-4 text-2xl text-bleu font-bold">×</button>
                <h2 class="text-center mb-6">Modifier mon profil</h2>
                <form method="POST" enctype="multipart/form-data" class="flex flex-col *:w-full *:font-comforta">
                    <div class="flex w-full *:flex-1 gap-2.5 *:min-w-0">
                        <input 
                            type="text" 
                            name="name"
                            value={user.name || ''}
                            placeholder="Nom"
                            class="px-2 py-3 border-2 border-bleu bg-white rounded-lg mb-2.5"
                        />

                        <input 
                            type="text" 
                            name="surname"
                            value={user.surname || ''}
                            placeholder="Prénom"
                            class="px-2 py-3 border-2 border-bleu bg-white rounded-lg mb-2.5"
                        />
                    </div>

                    <label class="text-sm text-bleu mb-1">Adresse mail</label>
                    <input 
                        type="email" 
                        name="email"
                        value={user.email || ''}
                        placeholder="Adresse mail"
                        class="px-2 py-3 border-2 border-bleu bg-white rounded-lg mb-2.5"
                    />

                    <label class="text-sm text-bleu mb-1">Photo de profil</label>
                    <input 
                        type="file" 
                        name="avatar"
                        accept="image/*"
                        class="px-2 py-2 border-2 border-bleu bg-white rounded-lg mb-2.5"
                    />

                    {user.coach && (
                        <div class="flex flex-col">

                            <label class="text-sm text-bleu mb-1">Votre description</label>
                            <textarea 
                                name="description"
                                placeholder="Description"
                                class="px-2 py-3 border-2 border-bleu bg-white rounded-lg mb-2.5 min-h-24"
                            >{user.description || ''}</textarea>

                            <label class="text-sm text-bleu mb-1">Pseudo</label>
                            <input 
                                type="text"
                                name="pseudo"
                                value={user.pseudo || ''}
                                placeholder="Pseudo"
                                class="px-2 py-3 border-2 border-bleu bg-white rounded-lg mb-2.5"
                            />

                            <label class="text-sm text-bleu mb-1">Votre Spécialisation</label>
                            <select name="specialisation" class="px-2 py-3 border-2 border-bleu bg-white rounded-lg mb-2.5">
                                <option value="">Spécialisation</option>
                                {specialisations.map((spe) => (
                                    <option value={spe} selected={user.specialisation === spe}>{spe}</option>
                                ))}
                            </select>
                        </div>
                    )}

                    <button class="text-beige bg-bleu font-bold text-lg w-full rounded-xl py-1 cursor-pointer mt-2">
                        Enregistrer
                    </button>
                </form>
            </div>
        </div>

        <div class="bg-beige rounded-[10px] border border-bleu p-4 w-9/10 mx-auto">
            <p class="text-bleu font-bold">Email: <span class="font-normal">{user.email}</span></p>
            <p class="text-bleu font-bold mt-2">Utilisateur depuis: <span class="font-normal">{new Date(user.created).toLocaleDateString('fr-FR')}</span></p>
        </div>

        <div id="recettes-fav" class="hidden bg-beige rounded-[10px] border border-bleu p-4 w-9/10 mx-auto max-h-72 overflow-auto">
            <h2>Vos favoris</h2>
            {recettesFavUser.length === 0 ? (
                <p>Vous n'avez pas encore ajouté de recette en favoris.</p>
            ):(
                <ul class="*:my-2.5">
                    {recettesFavUser.map((favori) => {
                        const recetteFav = favori.expand?.recette;
                        if (!recetteFav) return null;

                        return (
                        <li class="bg-beige border border-bleu rounded-xl p-3">
                            <div class="flex flex-wrap justify-between gap-2 place-items-center">
                                <a href={`/recettes/${recetteFav.id}`} class="text-bleu text-xl font-bold underline hover:decoration-0">{recetteFav.titre}</a>
                                <div class="text-right">
                                    <p>{favRecetteStats[recetteFav.id]?.nbAvis ?? 0} avis</p>
                                    <p class="font-bold text-bleu">{favRecetteStats[recetteFav.id]?.moyenne ?? 0}/5</p>
                                </div>
                            </div>
                            <div class="*:my-2">
                                <form method="post">
                                    <input type="hidden" name="favori" value={favori.id}/>
                                    <input type="hidden" name="unfavorite" value="true"/>
                                    <button type="submit" class="text-beige bg-red-400 border p-2 rounded-xl hover:text-red-400 hover:bg-beige">Retirer des favoris</button>
                                </form>
                            </div>
                        </li>
                        );
                    })}
                </ul>
            )}
        </div>

        <div id="recettes" class="hidden bg-beige rounded-[10px] border border-bleu p-4 w-9/10 mx-auto max-h-72 overflow-auto">
            <h2>Vos recettes</h2>
            {recettesUser.length === 0 ? (
                <p>Vous n'aves pas encore posté de recette, pourquoi pas <a href="/recettes/add" class="text-bleu underline hover:decoration-0">commencer maintenant</a> ?</p>
            ):(
                <ul class="*:my-2.5">
                    {recettesUser.map((recette) => (
                        <li class="bg-beige border border-bleu rounded-xl p-3">
                            <div class="flex flex-wrap justify-between gap-2 place-items-center">
                                <a href={`/recettes/${recette.id}`} class="text-bleu text-xl font-bold underline hover:decoration-0">{recette.titre}</a>
                                <div class="text-right">
                                    <p>{recetteStats[recette.id]?.nbAvis ?? 0} avis</p>
                                    <p class="font-bold text-bleu">{recetteStats[recette.id]?.moyenne ?? 0}/5</p>
                                </div>
                            </div>
                            <div class="*:my-2">
                                <a href={`recettes/edit/${recette.id}`} class="bg-bleu text-beige border p-2 rounded-xl hover:bg-beige hover:text-bleu">Editer la recette</a>
                                <form method="post">
                                    <input type="hidden" name="recette" value={recette.id}/>
                                    <input type="hidden" name="delete" value="true">
                                    <button type="submit" class="text-beige bg-red-400 border p-2 rounded-xl hover:text-red-400 hover:bg-beige">Supprimer</button>
                                </form>
                            </div>
                        </li>
                    ))}
                </ul>
            )}
        </div>

        {user.coach && (
            <>
                <div class="bg-beige h-full flex flex-col justify-around rounded-[10px] border border-bleu overflow-auto p-2 w-9/10 mx-auto *:flex-1 *:my-3">
                    <h2 class="text-bleu font-bold">Statistiques Coach</h2>
                    <div class="flex w-9/10 mx-auto justify-around">
                        <p>{nb_com} avis</p>
                        <div class="flex place-items-center justify-around *:mx-1.5 w-5/10">
                            <ProgressBar note={moyenne} color="bleu"/>
                            <p>{moyenne}/5</p>
                        </div>
                    </div>
                </div>
                {fiche?.lien && (
                    <a
                        href={fiche.lien}
                        target="_blank"
                        rel="noreferrer"
                        class="block w-fit font-comforta font-bold bg-bleu text-beige mx-auto p-2.5 rounded-full border hover:bg-beige hover:text-bleu transition-all duration-100"
                    >
                        Voir mon profil coach
                    </a>
                )}

                <div class="w-9/10 mx-auto">
                    <h2>Avis reçus</h2>
                    {commentaires.length === 0 ? (
                        <p class="bg-beige text-bleu border-2 rounded-xl mx-auto mb-12 p-1 text-center">
                            Aucun avis pour le moment
                        </p>
                    ):(
                        <ul class="*:my-2">
                            {commentaires.map((com) => (
                                <li><CardCommentaireCoach com={com}/></li>
                            ))}
                        </ul>
                    )}
                </div>
            </>
        )}
    </main>
    <script>
        const fenetreEditUser = document.getElementById('edit-profile-user');
        const btnEditUser = document.getElementById('edit-user');
        const btnCloseUser = document.getElementById('closeUser');

        const btnRecettes = document.getElementById("recettes-user");
        const fenetreRecettes = document.getElementById("recettes");

        const btnRecettesFav = document.getElementById("recettes-user-fav");
        const fenetreRecettesFav = document.getElementById("recettes-fav");

        btnRecettesFav?.addEventListener('click', () => {
            if (
                fenetreRecettesFav?.classList.contains("hidden")) 
            {
                fenetreRecettesFav?.classList.remove("hidden");
            }
            else {fenetreRecettesFav?.classList.add("hidden")}
        })

        btnRecettes?.addEventListener('click', () => {
            if (
                fenetreRecettes?.classList.contains("hidden")) 
            {
                fenetreRecettes?.classList.remove("hidden");
            }
            else {fenetreRecettes?.classList.add("hidden")}
        })

        btnEditUser?.addEventListener('click', () => {
            fenetreEditUser?.classList.remove('opacity-0', 'pointer-events-none');
            fenetreEditUser?.classList.add('flex', 'opacity-100');
        });

        const closefenetreEditUserl = () => {
            fenetreEditUser?.classList.add('opacity-0', 'pointer-events-none');
            fenetreEditUser?.classList.remove('flex', 'opacity-100');
        };

        btnCloseUser?.addEventListener('click', closefenetreEditUserl);
        
        fenetreEditUser?.addEventListener('click', (e) => {
            if (e.target === fenetreEditUser) {
                closefenetreEditUserl();
            }
        });

    </script>
</Layout>