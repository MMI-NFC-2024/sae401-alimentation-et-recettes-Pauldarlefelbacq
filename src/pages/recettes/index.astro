---
import CardRecette from "../../components/Card_recette.astro";
import Layout from "../../layouts/Layout.astro";
import { RecettesTypeOptions } from "../../pocketbase-types";

if (Astro.request.method === "POST") {
    const userId = Astro.locals.pb.authStore.record?.id;
    const formData = await Astro.request.formData();
    const recetteId = String(formData.get("recetteId") ?? "").trim();

    if (userId && recetteId) {
        try {
            const existing = await Astro.locals.pb.collection("Favori").getList(1, 1, {
                filter: `user = "${userId}" && recette = "${recetteId}"`,
            });

            if (existing.items.length > 0) {
                await Astro.locals.pb.collection("Favori").delete(existing.items[0].id);
            } else {
                await Astro.locals.pb.collection("Favori").create({
                    user: userId,
                    recette: recetteId,
                });
            }
        } catch (error) {
            console.error("Favori toggle error:", error);
        }
    }

    return Astro.redirect(Astro.url.pathname + Astro.url.search, 303);
}

const recettes = await Astro.locals.pb.collection("Recettes").getFullList();
const categories = Object.values(RecettesTypeOptions);
const url = new URL(Astro.request.url);
const search = url.searchParams.get("s") ?? "";
const type = url.searchParams.get("t") ?? "";
const page = url.searchParams.get("p") ?? "";

const hasFilters = search.trim() !== "" || type.trim() !== "";

const recettesFilter = recettes.filter((i) => {
    const matchesSearch =
        !search || i.titre.toLowerCase().includes(search.toLowerCase());
    const matchesType =
        !type || i.type.toLowerCase().includes(type.toLowerCase());

    return matchesSearch && matchesType;
});
---
<Layout titre="Recettes">
    <h1 class="mt-20">Recettes</h1>
    <form action="/recettes" method="get" class="flex flex-col mb-2.5 h-fit justify-center place-items-center place-self-center">
        <input 
            type="search"
            name="s"
            value={search}
            placeholder="Rechercher une recette..."
            class="grid w-2/3 border-2 border-bleu rounded-lg bg-white my-5 mx-auto px-2 py-1 font-comforta"
        />
        <input type="hidden" name="t" value={type} />
        <div class="flex place-items-center">
            <button
                type="submit"
                class="bg-bleu text-beige p-2 rounded-xl border hover:bg-beige hover:text-bleu transition-all duration-100 h-fit"
            >
                Chercher
            </button>
            <a
                href={`/recettes${hasFilters ? `?t=${encodeURIComponent(type)}` : "" }`}
                class="bg-bleu text-beige p-3 rounded-xl border ml-5 hover:bg-beige hover:text-bleu transition-all duration-100 h-fit"
            >
                Réinitialiser
            </a>
        </div>
    </form>

    {Astro.locals.pb.authStore.isValid ? (
        <a href="/recettes/add" class="text-2xl block bg-bleu text-beige p-2.5 w-fit justify-self-center mx-auto rounded-xl border hover:bg-beige hover:text-bleu transition-all duration-150">Ajouter une recette</a>
    ):(
        <a href="/authpassword" class="block text-bleu underline w-fit justify-self-center mx-auto hover:decoration-0">Connectez vous pour partager une recette</a>
    )}

    <button id="filter-activation" class="bg-bleu text-beige text-center font-bold p-2.5 rounded-full mx-2.5 border hover:bg-beige hover:text-bleu transition-all duration-100">
        Filtrer
    </button>

    <div id="filter-panel" class="hidden grid grid-cols-1 bg-beige border border-bleu border-2 rounded-lg p-5 max-w-md w-full absolute left-1/2 top-1/3 -translate-1/2 gap-2">
        <button id="close-filter" class="absolute top-1 left-1  text-2xl text-bleu font-bold">×</button>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-2">
            {
            categories.map((cat) => (
                <a
                    href={`/recettes?t=${cat}${search ? `&s=${encodeURIComponent(search)}` : ""}`}
                    class="bg-bleu text-beige text-center font-bold p-2.5 rounded-full mx-2.5 border hover:bg-beige hover:text-bleu transition-all duration-100 w-auto"
                >
                    {cat}
                </a>
            ))
            }
        </div>
        <a 
            href={`/recettes${search ? `?s=${encodeURIComponent(search)}` : "" }`}
            class="bg-bleu text-beige font-bold p-2.5 w-fit h-fit rounded-full mx-2.5 border hover:bg-beige hover:text-bleu transition-all duration-100"
        >
            Réinitialiser
        </a>
    </div>
    {hasFilters ? (
        recettesFilter.length === 0 ? (
            <p class="bg-beige text-bleu border-2 border-bleu rounded-xl mx-auto mb-12 p-1 text-center w-9/10">
                Aucune recette ne correspond à votre recherche.
            </p>
        ):(
            <ul class="flex flex-wrap place-self-center justify-self-center *:my-3 place-items-baseline">
                {recettesFilter.map((recette) => (
                    <li class="place-self-center justify-self-center mx-auto">
                        <CardRecette recette={recette} />
                    </li>
                ))} 
            </ul>
        )
    ):(
        <ul class="flex flex-wrap place-self-center justify-self-center *:my-3 place-items-baseline">
            {recettes.map((recette) => (
                <li class="place-self-center justify-self-center mx-auto">
                    <CardRecette recette={recette} />
                </li>
            ))} 
        </ul>
    )}
     
    
   <script>
    const filterButton = document.getElementById("filter-activation");
    const closeFilterButton = document.getElementById("close-filter");
    const filterPanel = document.getElementById("filter-panel");

    filterButton?.addEventListener('click', () => {
        if(filterPanel?.classList.contains("hidden"))
        {
            filterPanel?.classList.remove("hidden")
        }
        else
        {
            filterPanel?.classList.add("hidden")
        }
    });

    const closeFilterPanelButton = () =>{
        filterPanel?.classList.add("hidden")
    };
    closeFilterButton?.addEventListener('click',closeFilterPanelButton);

    filterPanel?.addEventListener('click', (e) => {
            if (e.target !== filterPanel) {
                closeFilterPanelButton();
            }
        });
   </script>

</Layout>