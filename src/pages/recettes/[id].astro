---
import ImgPb from "../../components/ImgPb.astro";
import Layout from "../../layouts/Layout.astro";
import Button from '../../components/Button.astro';
import Moins from "../../assets/moins.svg";
import Plus from "../../assets/plus.svg";
import Arrow from "../../assets/arrow.svg";

import { formatHeure, checkHeure } from "../../utils/helper";
import { type UsersResponse, type CommentairesResponse, type RecettesResponse, type IngredientsDansRecetteResponse, type IngredientsResponse, type EtapesPrepResponse } from "../../pocketbase-types";
import CardCommentaire from "../../components/CardCommentaire.astro";
export const prerender = false;

type RecetteWithUser = RecettesResponse & {
    expand?: {
        user?: UsersResponse;
    };
};

type IngredientDansRecetteWithExpand = IngredientsDansRecetteResponse & {
    expand?: {
        ingredient?: IngredientsResponse;
    };
};

type CommentaireWithUser = CommentairesResponse & {
    expand?: {
        user?: UsersResponse;
    };
};

// Recette
const { id } = Astro.params as { id: string };
const recette = await Astro.locals.pb.collection("Recettes").getOne<RecetteWithUser>(id,{
    expand: 'user',
});
const auteur = await Astro.locals.pb.collection("users").getOne(recette.user);

// Comm
const commentaires = await Astro.locals.pb.collection("Commentaires").getFullList<CommentaireWithUser>({
    filter: `recette = "${recette.id}"`,
    expand: 'user',
})

//préparation
const preparation = await Astro.locals.pb.collection("Etapes_prep").getFullList<EtapesPrepResponse>({
    filter: `recette = "${recette.id}"`,
})

// Ingrédients
const ingredients = await Astro.locals.pb.collection("ingredients_dans_recette").getFullList<IngredientDansRecetteWithExpand>({
    filter: `recette = "${recette.id}"`,
    expand: 'ingredient'
})

//Commentaire
if (Astro.request.method === "POST") 
{
    const data = await Astro.request.formData();
    try 
    {
        const note = Number(data.get("note"));
        const contenu = data.get("contenu") as string;
        const user = Astro.locals.pb.authStore.record?.id;

        if (user) {
            await Astro.locals.pb.collection("Commentaires").create({
                note,
                contenu,
                user,
                recette: id,
            });

            return Astro.redirect(`${Astro.url.pathname}#commentaires`, 303);
        }
    } catch (e) {
        if (e instanceof Error) 
        {
            console.error(e.message);
        }
    }
}

//Nutrition long et répétitif...
let nbPers = recette.nb_personnes;

let calories = 0;
ingredients.forEach((ing) => {
    if (ing.expand?.ingredient?.unitaire)
    {
        calories += ing.expand.ingredient.calories * ing.quantite
    }
    else 
    {
        calories += ing.expand.ingredient.calories * (ing.quantite / 100)
    }
});
let calPers = calories / recette.nb_personnes;

let mat_grasses = 0;
ingredients.forEach((ing) => {
    if (ing.expand?.ingredient?.unitaire)
    {
        mat_grasses += ing.expand.ingredient.mat_grasses * ing.quantite
    }
    else 
    {
        mat_grasses += ing.expand.ingredient?.mat_grasses * (ing.quantite / 100)
    }
});
let matGPers = mat_grasses / recette.nb_personnes;

let proteines = 0;
ingredients.forEach((ing) => {
    if (ing.expand?.ingredient?.unitaire)
    {
        proteines += ing.expand.ingredient.proteines * ing.quantite
    }
    else 
    {
        proteines += ing.expand.ingredient.proteines * (ing.quantite / 100)
    }
});
let protPers = proteines / recette.nb_personnes;

let glucides = 0;
ingredients.forEach((ing) => {
    if (ing.expand?.ingredient?.unitaire)
    {
        glucides += ing.expand.ingredient.glucides * ing.quantite
    }
    else 
    {
        glucides += ing.expand.ingredient.glucides * (ing.quantite / 100)
    }
});
let gluPers = glucides / recette.nb_personnes;

const nb_com = commentaires.length;

---
<Layout titre={recette.titre}>
    <main class="*:my-5">
        <a href="/recettes">
            <Arrow class="rotate-90 size-20 mt-3 hover:*:fill-vert hover:*:stroke-bleu" />
        </a>
        <h1>{ recette.titre }</h1>
        <!-- img et créateur -->
        <section class="justify-items-end place-self-center grid w-9/10 mx-auto">
            <p class="px-2.5 py-1 bg-beige w-fit border border-bleu rounded-lg mb-1.5">Recette proposée par {auteur.coach ? <a href={`/coachs/${auteur.id}`} class="text-bleu underline active:text-vert">{auteur.surname}</a> : <span class="text-bleu underline active:text-vert">{auteur.surname}</span>}</p>
            <ImgPb
            record={recette}
            image={recette.image}
            alt={`image de ${recette.titre}`}
            classPicture="w-full h-full mx-auto"
            classImg="w-full h-[250px] object-cover rounded-xl"/>
        </section>
        <section class="flex place-items-center justify-around">
            <Button texte={recette.type}/>
            <a href="#commentaires" class="text-bleu font-bold underline">{nb_com} avis</a>
        </section>
        <!-- Tps nécéssaire -->
        <section class="flex place-items-center justify-around bg-beige border border-bleu rounded-xl w-fit gap-12 px-5 py-1 mx-auto">
            <div class="flex flex-col place-items-center">
                <div>
                    Cuisson
                </div>
                <div class="flex text-bleu">
                    <p>{formatHeure(recette.temps_cuisson)}</p>
                    {checkHeure(recette.temps_cuisson) ? (
                        <p>h</p>
                        ):(
                        <p>mins</p>
                    )}
                </div>
            </div>
            <div class="flex flex-col place-items-center ">
                <div>
                    Préparation
                </div>
                <div class="flex text-bleu">
                    <p>{formatHeure(recette.temps_prep)}</p>
                    {checkHeure(recette.temps_prep) ? (
                    <p>h</p>
                    ):(
                    <p>mins</p>
                    )}
                </div>
            </div>
        </section>
        <!-- Description -->
        <section>
            <h2 class="w-9/10 mx-auto">Description</h2>
            <p class="bg-beige border border-bleu rounded-xl p-3.5 w-9/10 mx-auto">{recette.description}</p>
        </section>
        <!-- Ingrédients -->
        <section>
            <div>
                <div class="flex justify-between place-items-center w-9/10 mx-auto mb-2.5">
                    <h2 class="w-9/10 mx-auto">Ingrédients</h2>
                    <div class="flex border w-fit place-items-center gap-1 *:px-1.5 *:py-1 rounded-lg">
                        <button id="moins" class="flex-1 cursor-pointer"><Moins /></button>
                        <button id="nb-pers" class="grow whitespace-nowrap bg-bleu text-beige h-full">{nbPers} personnes</button>
                        <button id="plus" class="flex-1 cursor-pointer"><Plus /></button>
                    </div>
                </div>
                <ul class="grid grid-cols-2 bg-beige w-9/10 mx-auto p-3.5 border border-bleu rounded-xl">
                    {
                        ingredients.map((ing) => (
                        <li>{ing.expand?.ingredient?.nom}</li>
                        <li class="justify-self-end">
                            <span
                                class="ingredient-qty"
                                data-qty={ing.quantite}
                                data-unit={ing.unite}
                            >
                                {(ing.quantite / recette.nb_personnes) * nbPers}{ing.unite}
                            </span>
                        </li>
                        ))
                    }
                </ul>
            </div>
        </section>
        <!-- Valeurs nutritionnelles -->
        <section>
            <h2 class="w-9/10 mx-auto">Valeurs nutritionnelles</h2>
            <div>
                <ul class="grid grid-cols-2 bg-beige w-9/10 mx-auto p-3.5 border border-bleu rounded-xl">
                    <li>Calories</li>
                    <li id="calories-value" class="justify-self-end">{ Math.round((calPers) * nbPers) } Kcal</li>
                    <li>Protéines</li>
                    <li id="proteines-value" class="justify-self-end">{ Math.round((protPers) * nbPers) } g</li>
                    <li>Glucides</li>
                    <li id="glucides-value" class="justify-self-end">{ Math.round((gluPers) * nbPers) } g</li>
                    <li>Matières grasses</li>
                    <li id="matgrasses-value" class="justify-self-end">{ Math.round((matGPers) * nbPers) } g</li>
                </ul>
            </div>
        </section>
        <!-- Etapes de préparation -->
        <section>
            <h2 class="w-9/10 mx-auto">Préparation</h2>
            <ul>
                {
                    preparation.map((prep, index) => (
                    <li class="bg-beige w-9/10 mx-auto border border-bleu rounded-xl my-2.5 p-3.5">
                        <p class="text-xl text-bleu underline">Étape {index + 1}</p>
                        <p>{prep.contenu}</p>
                    </li>
                    ))
                }
            </ul>
        </section>
        <!-- Commentaires -->
        <section id="commentaires">
            <h2 class="w-9/10 mx-auto">Commentaires</h2>
            <div class="*:my-5">
                {
                    commentaires.map((com) => (
                    <CardCommentaire com={com} />
                    ))
                }
            </div>
        </section>
        <section>
            {Astro.locals.pb.authStore.isValid ? (
                <h2 class="w-9/10 mx-auto">Poster un commentaire</h2>
                <form method="POST" action={Astro.url.pathname} class="flex flex-col *:my-1.5 w-9/10 mx-auto">
                    <label>
                        <span>Note</span>
                        <input 
                            type="number"
                            name="note"
                            max="5"
                            min="0"
                            class="bg-vert text-bleu font-comforta p-1.5 rounded-md"
                            required
                        />
                    </label>
                        <textarea 
                            name="contenu"
                            rows="5"
                            class="bg-beige border-4 rounded-xl border-vert font-comforta p-2"
                            required
                        />
                    <button 
                        class="bg-vert text-bleu text-xl font-bold font-comforta w-fit py-3 px-5 rounded-xl mx-auto cursor-pointer hover:bg-bleu hover:text-vert transition duration-100"
                    >
                        Envoyer
                    </button>
                </form>
            ) : (
                <p>Il est nécéssaire de vous <a href="">connecter</a> pour poster un commentaire</p>
            )}
        </section>
    </main>

    <script is:inline define:vars={{ nbPers, calPers, protPers, gluPers, matGPers }}>
        const btnPlus = document.getElementById("plus");
        const btnMoins = document.getElementById("moins");
        const nbPersDisplay = document.getElementById("nb-pers");
        const caloriesValue = document.getElementById("calories-value");
        const proteinesValue = document.getElementById("proteines-value");
        const glucidesValue = document.getElementById("glucides-value");
        const matGrassesValue = document.getElementById("matgrasses-value");
        let currentNbPers = nbPers;

        const render = () => {
            if (nbPersDisplay) nbPersDisplay.textContent = `${currentNbPers} personnes`;

            document.querySelectorAll('.ingredient-qty').forEach((el) => {
                const baseQty = Number(el.getAttribute('data-qty') || 0);
                const unit = el.getAttribute('data-unit') || '';
                const scaled = (baseQty / nbPers) * currentNbPers;
                el.textContent = `${Math.round(scaled * 100) / 100}${unit}`;
            });

            if (caloriesValue) caloriesValue.textContent = `${Math.round(calPers * currentNbPers)} Kcal`;
            if (proteinesValue) proteinesValue.textContent = `${Math.round(protPers * currentNbPers)} g`;
            if (glucidesValue) glucidesValue.textContent = `${Math.round(gluPers * currentNbPers)} g`;
            if (matGrassesValue) matGrassesValue.textContent = `${Math.round(matGPers * currentNbPers)} g`;
        };

        btnPlus?.addEventListener('click', () => {
            currentNbPers += 1;
            render();
        });

        btnMoins?.addEventListener('click', () => {
            if (currentNbPers > 1) {
                currentNbPers -= 1;
                render();
            }
        });

        render();
    </script>
</Layout>